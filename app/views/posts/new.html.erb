<h2>Create a New Post</h2>

<%= form_with model: @post, local: true, html: { multipart: true } do |f| %>
  <div>
    <%= f.label :title %>
    <%= f.text_field :title %>
  </div>

  <div>
    <%= f.label :content %>
    <%= f.text_area :content %>
  </div>

  <!-- Category Dropdown -->
  <div>
    <%= f.label :category_id, "Select Category" %>
    <%= f.collection_select :category_id, Category.all, :id, :name, include_blank: "None" %>
  </div>


  <div>
    <%= f.label :image, "Upload an Image (optional)" %>
    <%= f.file_field :image %>
  </div>

  <div>
    <%= f.submit "Create Post" %>
  </div>
<% end %>

<%= link_to "Back to Posts", root_path %>
